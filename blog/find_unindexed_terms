#!/bin/bash

jq -r '.[].term' glossary.json | while read -r term; do
    echo "--- Suche nach: $term ---"

    # Wir suchen nach dem Begriff, aber filtern Zeilen aus,
    # die das Muster \index{Begriff} enthalten.
    grep -rn --include="*.php" --exclude-dir="Set" "$term" . | grep -v "\\\\index{$term}"

    echo ""
done
