		"6": "mat",
		"7": "field",
		"8": "and",
		"9": "a"
	},
	"sentences": [
		"the cat sat on the mat",
		"the dog ran on the field"
	],
	"text_display": [
		"the \u2192 cat",
		"the cat \u2192 sat",
		"the cat sat \u2192 on",
		"the cat sat on \u2192 the",
		"the cat sat on the \u2192 mat",
		"the \u2192 dog",
